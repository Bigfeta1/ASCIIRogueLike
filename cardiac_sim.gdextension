[configuration]
entry_symbol = "cardiac_sim_library_init"
compatibility_minimum = "4.5"

[libraries]
linux.debug.x86_64   = "res://cardiac_sim/bin/libcardiac_sim.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://cardiac_sim/bin/libcardiac_sim.linux.template_release.x86_64.so"
windows.debug.x86_64   = "res://cardiac_sim/bin/libcardiac_sim.windows.template_release.x86_64.dll"
windows.release.x86_64 = "res://cardiac_sim/bin/libcardiac_sim.windows.template_release.x86_64.dll"
